# Real deployed secrets - never commit these. Use configs/*.example.yaml instead.
configs/server.yaml
configs/client.yaml

# Android release signing - never commit the actual key/password. Losing this file
# means future releases can't be installed as an update over existing installs
# (Android requires matching signatures) - back it up somewhere safe, just not here.
android/phantom-release.keystore
android/keystore.properties

# Build artifacts
bin/
*.apk
*.aar
*.jar

# Go
*.exe
*.test

# Android
android/.gradle/
android/app/build/
android/build/
android/local.properties
android/app/libs/*.aar
android/app/libs/*.jar
*.iml
.idea/

# OS/editor cruft
.DS_Store
Thumbs.db
